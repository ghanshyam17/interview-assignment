# LLM API Configuration
# This project uses the FREE Groq API (https://console.groq.com/keys).

# Groq API Key (get a free key from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Select the provider to use: 'groq'
LLM_PROVIDER=groq

# Model Selection (Groq free-tier models with 131k context — no truncation needed):
# meta-llama/llama-4-scout-17b-16e-instruct (default, handles full term sheet text)
# llama-3.3-70b-versatile, llama-3.1-8b-instant
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct